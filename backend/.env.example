# Gmail OAuth2 Credentials — see GMAIL_SETUP.md for how to get these
GMAIL_CLIENT_ID=your_client_id_here
GMAIL_CLIENT_SECRET=your_client_secret_here
GMAIL_REFRESH_TOKEN=your_refresh_token_here

# Secret access token — share this URL with your team
# Generate a strong token: openssl rand -hex 32
ACCESS_TOKEN=replace_with_32_char_random_string

# Optional: only show emails from a specific sender/domain
# Examples: @mail.anthropic.com  |  noreply@github.com  |  @cursor.sh
# Leave empty to show all inbox emails
GMAIL_FILTER_FROM=@mail.anthropic.com

# Optional: restrict CORS to your frontend domain (default: *)
# CORS_ORIGIN=https://your-domain.com

# Backend port (default: 3001)
PORT=3001
