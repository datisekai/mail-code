# ── Gmail OAuth2 (see GMAIL_SETUP.md) ─────────────────────────────────────────
GMAIL_CLIENT_ID=your_client_id_here
GMAIL_CLIENT_SECRET=your_client_secret_here
GMAIL_REFRESH_TOKEN=your_refresh_token_here

# ── Access control ─────────────────────────────────────────────────────────────
# Share this URL with your team: http://YOUR_DOMAIN:3000/inbox/<ACCESS_TOKEN>
# Generate: openssl rand -hex 32
ACCESS_TOKEN=replace_with_32_char_random_string

# ── Frontend → Backend URL (browser-facing) ────────────────────────────────────
# Backend API domain (browser-facing)
# Production: https://api-claude.unnamedui.com
# Local dev:  http://localhost:3007
NEXT_PUBLIC_API_URL=https://api-claude.unnamedui.com

# ── Optional ───────────────────────────────────────────────────────────────────
CORS_ORIGIN=https://claude.unnamedui.com
PORT=3001
